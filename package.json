{
  "name": "thea",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate": "tsx scripts/migrate.ts",
    "dev:setup": "docker compose up -d postgres && sleep 3 && npm run migrate"
  },
  "dependencies": {
    "@clerk/nextjs": "^5.7.0",
    "@sentry/nextjs": "^8.0.0",
    "next": "14.2.16",
    "pino": "^9.4.0",
    "postgres": "^3.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.16",
    "jsdom": "^25.0.0",
    "pino-pretty": "^13.0.0",
    "postcss": "^8.4.41",
    "tsx": "^4.19.0",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
