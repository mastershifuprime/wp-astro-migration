# Clerk Auth — https://clerk.com/docs/quickstarts/nextjs
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Database
# Local dev (matches docker-compose.yml):
#   DATABASE_URL=postgres://thea:thea_dev_secret@localhost:5432/thea_dev
# Vercel Postgres (production) — copy from Vercel dashboard → Storage → your DB → .env.local
DATABASE_URL=postgres://...

# Sentry (optional in dev — leave blank to disable)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=debug
